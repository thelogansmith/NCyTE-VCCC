<?xml version="1.0" encoding="UTF-8"?>
<!--
  CTA Site - web.config
  =====================
  Place this file in C:\inetpub\wwwroot\ (the CTA site root).
  If a web.config already exists there, merge the <appSettings> block below
  into it — do NOT replace the entire file.

  SETUP INSTRUCTIONS:
  1. Replace PASTE_YOUR_API_KEY_HERE with your Cyberlab API key.
  2. Replace PASTE_YOUR_MODEL_NAME_HERE with your assigned model, e.g. mistral:7b
  3. Save the file. IIS picks up the change immediately — no restart needed.
  4. The key is stored here on the server only. It is never sent to the browser.
-->
<configuration>

  <appSettings>
    <!-- Cyberlab OpenWebUI API credentials — keep this file private -->
    <add key="CyberlabApiKey"  value="PASTE_YOUR_API_KEY_HERE" />
    <add key="CyberlabApiBase" value="https://ai.cyberlab.csusb.edu/api" />
    <!-- Model assigned to your team, e.g. mistral:7b or gemma3n:e4b -->
    <add key="CyberlabModel"   value="PASTE_YOUR_MODEL_NAME_HERE" />
  </appSettings>

  <system.webServer>

    <!-- Prevent the browser from ever directly accessing the proxy or config -->
    <security>
      <requestFiltering>
        <hiddenSegments>
          <add segment="web.config" />
        </hiddenSegments>
      </requestFiltering>
    </security>

    <!-- Block direct browser GET requests to the proxy endpoint -->
    <rewrite>
      <rules>
        <rule name="Block direct proxy access" stopProcessing="true">
          <match url="^proxy\.aspx$" />
          <conditions>
            <add input="{REQUEST_METHOD}" pattern="^GET$" />
          </conditions>
          <action type="CustomResponse" statusCode="404" statusReason="Not Found" statusDescription="Not Found" />
        </rule>
      </rules>
    </rewrite>

    <defaultDocument>
      <files>
        <add value="index.html" />
      </files>
    </defaultDocument>

  </system.webServer>

</configuration>
