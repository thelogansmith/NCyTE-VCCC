const fs = require('fs');

const timestamp = new Date().toISOString();
const totalCpu = $('Code').item.json.totalCpu.toFixed(1);
const userCpu = $('Code').item.json.user.toFixed(1);
const systemCpu = $('Code').item.json.system.toFixed(1);
const aiSummary = $input.item.json.choices[0].message.content.replace(/\n/g, ' ');

const logLine = `${timestamp} | ALERT | CPU: ${totalCpu}% (user: ${userCpu}%, sys: ${systemCpu}%) | ${aiSummary}\n`;

fs.appendFileSync('/var/log/n8n-security-events.log', logLine);

return [{ json: { success: true, logLine } }];




